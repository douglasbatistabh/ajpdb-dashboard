# =====================================================================
# Integração AJPDB - Dashboard - Variáveis de ambiente
# =====================================================================
#
# Para desenvolvimento local: copie este arquivo para .env.local e preencha
# Para produção (Vercel): adicione estas variáveis no painel da Vercel
#
# =====================================================================

# NextAuth - secret para assinar JWTs
# Gere com: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth - obter em https://console.cloud.google.com/apis/credentials
# Crie credenciais "OAuth Client ID" tipo "Web application"
# Authorized redirect URI: https://seu-app.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# URL base do app (apenas em produção - a Vercel preenche automaticamente)
# AUTH_URL=https://ajpdb-dashboard.vercel.app
